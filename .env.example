# Copy this file to `.env` in the same folder and fill in real values.
# Next.js and Prisma both read `.env` (and Next also reads `.env.local`).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
OPENAI_API_KEY="sk-..."
# Optional IANA zone when Vercel does not send x-vercel-ip-timezone (e.g. Europe/Kyiv)
TASK_PARSER_TIMEZONE=""
