# Copy this file to `.env` in the same folder and fill in real values.
# Next.js and Prisma both read `.env` (and Next also reads `.env.local`).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
OPENAI_API_KEY="sk-..."
# Optional IANA zone when Vercel does not send x-vercel-ip-timezone (e.g. Europe/Kyiv)
TASK_PARSER_TIMEZONE=""

# Auth.js / Google OAuth (https://console.cloud.google.com/apis/credentials)
# Create an OAuth 2.0 Web client; authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_SECRET=""
# Public site URL (Vercel sets this automatically; for local dev use http://localhost:3000)
AUTH_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
