# Copy this file to `.env` in the same folder and fill in real values.
# Next.js and Prisma both read `.env` (and Next also reads `.env.local`).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
OPENAI_API_KEY="sk-..."
# Optional IANA zone when Vercel does not send x-vercel-ip-timezone (e.g. Europe/Kyiv)
TASK_PARSER_TIMEZONE=""

# --- Google sign-in (Auth.js) — “Sign in with Google”, not the Authenticator app ---
# 1) Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application
# 2) Authorized redirect URIs (add every environment you use):
#    http://localhost:3000/api/auth/callback/google
#    https://YOUR-VERCEL-APP.vercel.app/api/auth/callback/google
# 3) Optional: APIs & Services → Library → enable “Google Calendar API” for protocol export.
AUTH_SECRET=""
# Local: http://localhost:3000   Production: https://your-domain.com  (Vercel often sets VERCEL_URL; set AUTH_URL explicitly if sign-in redirects fail)
AUTH_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
